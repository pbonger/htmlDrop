<idea-plugin>
    <id>html-drop</id>
    <name>HTML Drop</name>
    <vendor>pbonger</vendor>
    <description><![CDATA[
        Right-click any HTML file → <b>Share on HTML Drop</b>.<br/>
        Uploads to pagedrop.io, copies the URL to clipboard, shows a balloon notification.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="HTML Drop" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="htmldrop.ShareOnHTMLDropAction"
                class="htmldrop.ShareOnHTMLDropAction"
                icon="/icons/icon16.png"
                text="Share on HTML Drop"
                description="Upload this HTML file to HTML Drop and copy the URL to clipboard">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
